<Window x:Class="Photo_zip.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Photo_zip.Converters"
        Title="Imagility"
        Icon="pack://application:,,,/Assets/logo.png"
        Width="1120"
        Height="760"
        MinWidth="900"
        MinHeight="620"
        Background="{StaticResource AppBackgroundBrush}"
        AllowDrop="True"
        DragOver="Window_DragOver"
        Drop="Window_Drop"
        KeyDown="Window_KeyDown"
        Deactivated="Window_Deactivated">
    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
        <Style x:Key="ImageListCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="22" Height="22" Background="Transparent">
                            <Border x:Name="CheckBoxBorder"
                                    Width="18"
                                    Height="18"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Background="White"
                                    BorderBrush="#CBD5E1"
                                    BorderThickness="1.4"
                                    CornerRadius="5" />
                            <Path x:Name="CheckMark"
                                  Width="10"
                                  Height="8"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Data="M 1 4 L 4 7 L 9 1"
                                  Stretch="Fill"
                                  Stroke="White"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Visibility="Collapsed" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="#93C5FD" />
                                <Setter TargetName="CheckBoxBorder" Property="Background" Value="#EFF6FF" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBoxBorder" Property="Background" Value="#3B82F6" />
                                <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="#3B82F6" />
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" MinWidth="240" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Background="{StaticResource CardBrush}" CornerRadius="16" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="12">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="图片列表" FontSize="20" FontWeight="Bold" Foreground="#0F172A" />
                    <TextBlock Text="支持拖拽，勾选后参与批量处理" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,12" />
                    <WrapPanel Margin="0,0,0,14">
                        <Button Content="添加图片" Click="AddImages_Click" Margin="0,0,8,8" />
                        <Button Content="全选" Style="{StaticResource SecondaryButtonStyle}" Click="SelectAll_Click" Margin="0,0,8,8" />
                        <Button Content="取消全选" Style="{StaticResource SecondaryButtonStyle}" Click="UnselectAll_Click" Margin="0,0,8,8" />
                        <Button Content="移除选中图片" Style="{StaticResource SecondaryButtonStyle}" Click="RemoveSelected_Click" IsEnabled="{Binding HasCheckedImages}" Margin="0,0,8,8" />
                        <Button Content="移除全部" Style="{StaticResource SecondaryButtonStyle}" Click="ClearList_Click" Margin="0,0,8,8" />
                    </WrapPanel>
                </StackPanel>

                <Grid>
                    <TextBlock Text="暂无图片。点击添加图片，或拖入图片/文件夹。"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="220"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="14"
                               Visibility="{Binding HasItems, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />

                    <ListBox x:Name="ImageListBox"
                             ItemsSource="{Binding Images}"
                             SelectedItem="{Binding SelectedImage, Mode=TwoWay}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             Visibility="{Binding HasItems, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Margin" Value="0,0,0,10" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="Transparent" Padding="0">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="ImageItemCard" Background="#F8FAFC" CornerRadius="12" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30" />
                                            <ColumnDefinition Width="76" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" Style="{StaticResource ImageListCheckBoxStyle}" IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center" />
                                        <Border Grid.Column="1" Width="64" Height="64" Background="#E2E8F0" CornerRadius="10" ClipToBounds="True">
                                            <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" />
                                        </Border>
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0">
                                            <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" Foreground="#0F172A" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Foreground="{StaticResource MutedTextBrush}" Margin="0,5,0,0" TextTrimming="CharacterEllipsis">
                                                <Run Text="{Binding OriginalSizeText, Mode=OneWay}" />
                                                <Run Text="  ·  " />
                                                <Run Text="{Binding Format, Mode=OneWay}" />
                                                <Run Text="  ·  " />
                                                <Run Text="{Binding DimensionText, Mode=OneWay}" />
                                            </TextBlock>
                                            <TextBlock Text="{Binding Status}" Foreground="#2563EB" Margin="0,5,0,0" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                        <Setter TargetName="ImageItemCard" Property="Background" Value="#EFF6FF" />
                                        <Setter TargetName="ImageItemCard" Property="BorderBrush" Value="#93C5FD" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </DockPanel>
        </Border>

        <Border Grid.Row="0" Grid.Column="2" Background="{StaticResource CardBrush}" CornerRadius="16" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="300" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="280" MinWidth="250" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.ColumnSpan="3">
                    <TextBlock Text="预览与参数" FontSize="20" FontWeight="Bold" Foreground="#0F172A" />
                    <DockPanel Margin="0,4,0,12">
                        <WrapPanel DockPanel.Dock="Right" Margin="12,0,0,0">
                            <Button Content="新建签名" Style="{StaticResource SecondaryButtonStyle}" Click="CreateSignature_Click" MinWidth="78" Margin="0,0,8,0" />
                            <Button Content="插入签名" Click="InsertSignature_Click" IsEnabled="{Binding HasSelectedImage}" MinWidth="78" Margin="0,0,8,0" />
                            <Button Content="{Binding RedactionModeButtonText}" Click="ToggleRedactionMode_Click" MinWidth="72" Margin="0,0,8,0" />
                            <Button Content="撤销打码" Style="{StaticResource SecondaryButtonStyle}" Click="UndoRedaction_Click" IsEnabled="{Binding SelectedImage.CanUndoRedaction}" MinWidth="78" />
                        </WrapPanel>
                        <TextBlock Text="选中图片后生成编辑后预览；勾选 2 张及以上时显示拼接/拼贴效果" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />
                    </DockPanel>
                </StackPanel>

                <Grid Grid.Row="1" Grid.Column="0">
                    <Grid Visibility="{Binding HasSelectedImage, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#F8FAFC" BorderBrush="#DBEAFE" BorderThickness="1" CornerRadius="14" Padding="8">
                            <DockPanel>
                                <Border DockPanel.Dock="Top" Background="#EFF6FF" CornerRadius="10" Padding="10,6" Margin="0,0,0,10">
                                    <TextBlock Text="原图" Foreground="{StaticResource PrimaryDarkBrush}" FontWeight="SemiBold" />
                                </Border>
                                <Border Background="White" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="12" Padding="8">
                                    <Grid x:Name="RedactionCanvas"
                                          Cursor="{Binding RedactionCursor}"
                                          Background="Transparent"
                                          ClipToBounds="True"
                                          MouseLeftButtonDown="RedactionCanvas_MouseLeftButtonDown"
                                          MouseMove="RedactionCanvas_MouseMove"
                                          MouseLeftButtonUp="RedactionCanvas_MouseLeftButtonUp"
                                          MouseLeave="RedactionCanvas_MouseLeave"
                                          LostMouseCapture="RedactionCanvas_LostMouseCapture">
                                        <Image x:Name="PreviewImage" Source="{Binding SelectedImage.OriginalPreview}" Stretch="Uniform" />
                                        <Canvas x:Name="SignatureOverlayCanvas"
                                                Background="Transparent"
                                                MouseLeftButtonDown="SignatureOverlayCanvas_MouseLeftButtonDown"
                                                MouseMove="SignatureOverlayCanvas_MouseMove"
                                                MouseLeftButtonUp="SignatureOverlayCanvas_MouseLeftButtonUp"
                                                MouseWheel="SignatureOverlayCanvas_MouseWheel" />
                                        <Canvas IsHitTestVisible="False">
                                            <Polyline x:Name="RedactionStrokePreview"
                                                      Visibility="Collapsed"
                                                      Stroke="#2563EB"
                                                      StrokeThickness="32"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round"
                                                      Opacity="0.45" />
                                        </Canvas>
                                    </Grid>
                                </Border>
                            </DockPanel>
                        </Border>
                        <Border Grid.Column="2" Background="#F8FAFC" BorderBrush="#DBEAFE" BorderThickness="1" CornerRadius="14" Padding="8">
                            <DockPanel>
                                <Border DockPanel.Dock="Top" Background="#EFF6FF" CornerRadius="10" Padding="10,6" Margin="0,0,0,10">
                                    <TextBlock Text="编辑后预览" Foreground="{StaticResource PrimaryDarkBrush}" FontWeight="SemiBold" />
                                </Border>
                                <Border Background="White" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="12" Padding="8">
                                    <Grid>
                                        <Image Source="{Binding EditedPreview}" Stretch="Uniform" />
                                        <TextBlock Text="正在生成预览..."
                                                   Foreground="{StaticResource PrimaryDarkBrush}"
                                                   Background="#E6DBEAFE"
                                                   Padding="12,8"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding IsPreviewBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    </Grid>
                                </Border>
                            </DockPanel>
                        </Border>

                        <UniformGrid Grid.Row="1" Grid.ColumnSpan="3" Columns="3" Margin="0,14,0,0">
                            <Border Background="#F8FAFC" CornerRadius="12" Padding="12" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="原始大小" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock Text="{Binding SelectedImage.OriginalSizeText, Mode=OneWay}" FontSize="18" FontWeight="Bold" />
                                </StackPanel>
                            </Border>
                            <Border Background="#F8FAFC" CornerRadius="12" Padding="12" Margin="4,0,4,0">
                                <StackPanel>
                                    <TextBlock Text="预估大小" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock Text="{Binding SelectedImage.PreviewSizeText, Mode=OneWay}" FontSize="18" FontWeight="Bold" />
                                </StackPanel>
                            </Border>
                            <Border Background="#F8FAFC" CornerRadius="12" Padding="12" Margin="8,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="压缩率" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock Text="{Binding SelectedImage.CompressionRatioText, Mode=OneWay}" FontSize="18" FontWeight="Bold" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </Grid>

                    <TextBlock Text="请选择左侧列表中的图片查看预览。"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="16"
                               Foreground="{StaticResource MutedTextBrush}"
                               Visibility="{Binding HasSelectedImage, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                </Grid>

                <ScrollViewer Grid.Row="1"
                              Grid.Column="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="False">
                    <Border Background="#F8FAFC" CornerRadius="14" Padding="10">
                        <StackPanel>
                            <TextBlock Text="处理参数" FontSize="16" FontWeight="Bold" Foreground="#0F172A" />
                            <TextBlock Text="批量转换、拼接和输出设置" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,16" />

                            <Border Background="White" CornerRadius="14" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="14" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="基础输出" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,12" />

                                    <TextBlock Text="压缩质量" FontWeight="SemiBold" />
                                    <DockPanel Margin="0,8,0,12">
                                        <Border DockPanel.Dock="Right" Background="#DBEAFE" CornerRadius="9" Padding="10,4" Margin="12,0,0,0">
                                            <TextBlock Text="{Binding Quality}" MinWidth="28" TextAlignment="Center" Foreground="{StaticResource PrimaryDarkBrush}" FontWeight="Bold" />
                                        </Border>
                                        <Slider Minimum="0" Maximum="100" TickFrequency="5" IsSnapToTickEnabled="True" Value="{Binding Quality, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DockPanel>

                                    <CheckBox Content="按目标大小压缩" IsChecked="{Binding TargetSizeEnabled, Mode=TwoWay}" />
                                    <StackPanel IsEnabled="{Binding TargetSizeEnabled}" Margin="0,8,0,12">
                                        <TextBlock Text="目标大小（KB）" FontWeight="SemiBold" />
                                        <TextBox Text="{Binding TargetSizeKb, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:0.##}}" Margin="0,8,0,6" />
                                        <TextBlock Text="开启后会自动试探压缩质量；非 JPEG/WebP 输出会自动转为 JPEG，透明背景会转为 WebP。此设置作用于图片导出和拼接输出，PDF 仍按压缩质量生成。" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" />
                                    </StackPanel>

                                    <TextBlock Text="压缩模式" FontWeight="SemiBold" />
                                    <ComboBox ItemsSource="{Binding CompressionModes}" SelectedItem="{Binding SelectedCompressionMode, Mode=TwoWay}" Margin="0,8,0,12" />

                                    <TextBlock Text="输出格式" FontWeight="SemiBold" />
                                    <ComboBox ItemsSource="{Binding OutputFormats}" SelectedItem="{Binding SelectedOutputFormat, Mode=TwoWay}" Margin="0,8,0,12" />

                                    <TextBlock Text="文件名冲突" FontWeight="SemiBold" />
                                    <ComboBox ItemsSource="{Binding ConflictStrategies}" SelectedItem="{Binding SelectedConflictStrategy, Mode=TwoWay}" Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>

                            <Border Background="White" CornerRadius="14" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="14" Margin="0,0,0,12">
                                <StackPanel>
                                    <CheckBox Content="PNG 调色板量化" IsChecked="{Binding QuantizePng, Mode=TwoWay}" />
                                    <StackPanel IsEnabled="{Binding QuantizePng}" Margin="0,12,0,0">
                                        <TextBlock Text="颜色数量" FontWeight="SemiBold" />
                                        <DockPanel Margin="0,8,0,0">
                                            <Border DockPanel.Dock="Right" Background="#DBEAFE" CornerRadius="9" Padding="10,4" Margin="12,0,0,0">
                                                <TextBlock Text="{Binding PngColorCount}" MinWidth="34" TextAlignment="Center" Foreground="{StaticResource PrimaryDarkBrush}" FontWeight="Bold" />
                                            </Border>
                                            <Slider Minimum="2" Maximum="256" TickFrequency="1" Value="{Binding PngColorCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </DockPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Background="White" CornerRadius="14" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="14" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="快速涂改/打码" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,12" />
                                    <TextBlock Text="打码方式" FontWeight="SemiBold" />
                                    <ComboBox ItemsSource="{Binding RedactionModes}" SelectedItem="{Binding SelectedRedactionMode, Mode=TwoWay}" Margin="0,8,0,12" />

                                    <TextBlock Text="画笔粗细" FontWeight="SemiBold" />
                                    <DockPanel Margin="0,8,0,12">
                                        <Border DockPanel.Dock="Right" Background="#DBEAFE" CornerRadius="9" Padding="10,4" Margin="12,0,0,0">
                                            <TextBlock Text="{Binding RedactionBrushSize}" MinWidth="34" TextAlignment="Center" Foreground="{StaticResource PrimaryDarkBrush}" FontWeight="Bold" />
                                        </Border>
                                        <Slider Minimum="4" Maximum="120" TickFrequency="1" Value="{Binding RedactionBrushSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DockPanel>

                                    <TextBlock Text="马赛克块大小" FontWeight="SemiBold" />
                                    <DockPanel Margin="0,8,0,12">
                                        <Border DockPanel.Dock="Right" Background="#DBEAFE" CornerRadius="9" Padding="10,4" Margin="12,0,0,0">
                                            <TextBlock Text="{Binding MosaicBlockSize}" MinWidth="34" TextAlignment="Center" Foreground="{StaticResource PrimaryDarkBrush}" FontWeight="Bold" />
                                        </Border>
                                        <Slider Minimum="2" Maximum="32" TickFrequency="1" Value="{Binding MosaicBlockSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DockPanel>

                                    <TextBlock Text="高斯模糊半径" FontWeight="SemiBold" />
                                    <DockPanel Margin="0,8,0,12">
                                        <Border DockPanel.Dock="Right" Background="#DBEAFE" CornerRadius="9" Padding="10,4" Margin="12,0,0,0">
                                            <TextBlock Text="{Binding BlurRadius}" MinWidth="34" TextAlignment="Center" Foreground="{StaticResource PrimaryDarkBrush}" FontWeight="Bold" />
                                        </Border>
                                        <Slider Minimum="1" Maximum="20" TickFrequency="1" Value="{Binding BlurRadius, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DockPanel>

                                    <TextBlock Text="{Binding SelectedImage.RedactionStatusText}" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6" />
                                    <TextBlock Text="{Binding SelectedImage.SignatureStatusText}" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" />
                                </StackPanel>
                            </Border>

                            <Border Background="White" CornerRadius="14" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="14" Margin="0,0,0,12">
                                <StackPanel>
                                    <CheckBox Content="调整尺寸" IsChecked="{Binding ResizeEnabled, Mode=TwoWay}" />
                                    <Grid IsEnabled="{Binding ResizeEnabled}" Margin="0,12,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Row="0" Grid.Column="0">
                                            <TextBlock Text="宽度" FontWeight="SemiBold" />
                                            <TextBox Text="{Binding ResizeWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.##}}" Margin="0,8,0,0" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="0" Grid.Column="2">
                                            <TextBlock Text="高度" FontWeight="SemiBold" />
                                            <TextBox Text="{Binding ResizeHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.##}}" Margin="0,8,0,0" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,12,0,0">
                                            <TextBlock Text="单位" FontWeight="SemiBold" />
                                            <ComboBox ItemsSource="{Binding ResizeUnits}" SelectedItem="{Binding SelectedResizeUnit, Mode=TwoWay}" Margin="0,8,0,0" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,12,0,0">
                                            <TextBlock Text="DPI" FontWeight="SemiBold" />
                                            <TextBox Text="{Binding ResizeDpi, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,0" />
                                        </StackPanel>
                                        <CheckBox Grid.Row="2" Grid.ColumnSpan="3" Content="保持比例" IsChecked="{Binding KeepAspectRatio, Mode=TwoWay}" Margin="0,12,0,0" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Background="White" CornerRadius="14" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="14" Margin="0,0,0,12">
                                <StackPanel>
                                    <CheckBox Content="背景消除/替换" IsChecked="{Binding BackgroundProcessingEnabled, Mode=TwoWay}" />
                                    <Border Background="#F8FAFC" CornerRadius="12" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="10" Margin="0,12,0,0">
                                        <StackPanel>
                                            <TextBlock Text="证件照底色" FontWeight="SemiBold" Foreground="#0F172A" />
                                            <TextBlock Text="一键启用背景替换，适合蓝底、白底、红底等常用证件照。" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,10" />
                                            <WrapPanel>
                                                <Button Content="蓝底" Tag="#3B82F6" Click="ApplyIdPhotoBackgroundColor_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,8" />
                                                <Button Content="白底" Tag="#FFFFFF" Click="ApplyIdPhotoBackgroundColor_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,8" />
                                                <Button Content="红底" Tag="#EF4444" Click="ApplyIdPhotoBackgroundColor_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,8" />
                                                <Button Content="浅灰底" Tag="#F8FAFC" Click="ApplyIdPhotoBackgroundColor_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,8" />
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>
                                    <StackPanel IsEnabled="{Binding BackgroundProcessingEnabled}" Margin="0,12,0,0">
                                        <TextBlock Text="处理方式" FontWeight="SemiBold" />
                                        <ComboBox ItemsSource="{Binding BackgroundActions}" SelectedItem="{Binding SelectedBackgroundAction, Mode=TwoWay}" Margin="0,8,0,12" />

                                        <TextBlock Text="识别容差" FontWeight="SemiBold" />
                                        <DockPanel Margin="0,8,0,12">
                                            <Border DockPanel.Dock="Right" Background="#DBEAFE" CornerRadius="9" Padding="10,4" Margin="12,0,0,0">
                                                <TextBlock Text="{Binding BackgroundTolerance}" MinWidth="34" TextAlignment="Center" Foreground="{StaticResource PrimaryDarkBrush}" FontWeight="Bold" />
                                            </Border>
                                            <Slider Minimum="0" Maximum="255" TickFrequency="1" Value="{Binding BackgroundTolerance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </DockPanel>

                                        <TextBlock Text="边缘过渡" FontWeight="SemiBold" />
                                        <DockPanel Margin="0,8,0,12">
                                            <Border DockPanel.Dock="Right" Background="#DBEAFE" CornerRadius="9" Padding="10,4" Margin="12,0,0,0">
                                                <TextBlock Text="{Binding BackgroundFeather}" MinWidth="34" TextAlignment="Center" Foreground="{StaticResource PrimaryDarkBrush}" FontWeight="Bold" />
                                            </Border>
                                            <Slider Minimum="0" Maximum="100" TickFrequency="1" Value="{Binding BackgroundFeather, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </DockPanel>

                                        <TextBlock Text="替换色" FontWeight="SemiBold" />
                                        <TextBox Text="{Binding BackgroundReplacementColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,8" />
                                        <ItemsControl ItemsSource="{Binding BackgroundColorPalette}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Width="26" Height="26" Padding="0" Margin="0,0,8,8" Tag="{Binding}" Click="PickBackgroundReplacementColor_Click" ToolTip="{Binding}">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{Binding}"
                                                                        BorderBrush="#CBD5E1"
                                                                        BorderThickness="1"
                                                                        CornerRadius="13" />
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Background="White" CornerRadius="14" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="14" Margin="0,0,0,12">
                                <StackPanel>
                                    <CheckBox Content="添加水印" IsChecked="{Binding WatermarkEnabled, Mode=TwoWay}" />
                                    <StackPanel IsEnabled="{Binding WatermarkEnabled}" Margin="0,12,0,0">
                                        <TextBlock Text="水印文字" FontWeight="SemiBold" />
                                        <TextBox Text="{Binding WatermarkText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,12" />

                                        <TextBlock Text="位置" FontWeight="SemiBold" />
                                        <ComboBox ItemsSource="{Binding WatermarkPositions}" SelectedItem="{Binding SelectedWatermarkPosition, Mode=TwoWay}" Margin="0,8,0,12" />

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="100" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="水印透明度" FontWeight="SemiBold" />
                                                <DockPanel Margin="0,8,0,0">
                                                    <Border DockPanel.Dock="Right" Background="#DBEAFE" CornerRadius="9" Padding="10,4" Margin="12,0,0,0">
                                                        <TextBlock Text="{Binding WatermarkOpacity}" MinWidth="34" TextAlignment="Center" Foreground="{StaticResource PrimaryDarkBrush}" FontWeight="Bold" />
                                                    </Border>
                                                    <Slider Minimum="1" Maximum="100" TickFrequency="1" Value="{Binding WatermarkOpacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </DockPanel>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="字号" FontWeight="SemiBold" />
                                                <TextBox Text="{Binding WatermarkFontSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Background="White" CornerRadius="14" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="14" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="合并/拼接" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,12" />
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3">
                                            <TextBlock Text="拼贴模板" FontWeight="SemiBold" />
                                            <ComboBox ItemsSource="{Binding StitchModes}" SelectedItem="{Binding SelectedStitchMode, Mode=TwoWay}" Margin="0,8,0,0" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,12,0,0">
                                            <TextBlock Text="列数" FontWeight="SemiBold" />
                                            <TextBox Text="{Binding StitchColumns, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,0" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,12,0,0">
                                            <TextBlock Text="间距" FontWeight="SemiBold" />
                                            <TextBox Text="{Binding StitchSpacing, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,0" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,12,0,0">
                                            <TextBlock Text="画布宽度" FontWeight="SemiBold" />
                                            <TextBox Text="{Binding StitchCanvasWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,0" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,12,0,0">
                                            <TextBlock Text="画布高度" FontWeight="SemiBold" />
                                            <TextBox Text="{Binding StitchCanvasHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,0" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,12,0,0">
                                            <TextBlock Text="外边距" FontWeight="SemiBold" />
                                            <TextBox Text="{Binding StitchPadding, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,0" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="3" Grid.Column="2" Margin="0,12,0,0">
                                            <TextBlock Text="填充方式" FontWeight="SemiBold" />
                                            <ComboBox ItemsSource="{Binding CollageFitModes}" SelectedItem="{Binding SelectedCollageFitMode, Mode=TwoWay}" Margin="0,8,0,0" />
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Text="纵向/横向按原尺寸拼接；网格、瀑布流、主图海报和自由排列使用画布宽高、外边距和填充方式。" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" Margin="0,12,0,0" />
                                    <TextBlock Text="背景色" FontWeight="SemiBold" Margin="0,12,0,0" />
                                    <TextBox Text="{Binding StitchBackgroundColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,8" />
                                    <ItemsControl ItemsSource="{Binding BackgroundColorPalette}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Width="26" Height="26" Padding="0" Margin="0,0,8,8" Tag="{Binding}" Click="PickStitchBackgroundColor_Click" ToolTip="{Binding}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{Binding}"
                                                                    BorderBrush="#CBD5E1"
                                                                    BorderThickness="1"
                                                                    CornerRadius="13" />
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Background="White" CornerRadius="14" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="14" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="PDF 归档" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,12" />
                                    <TextBlock Text="导出方式" FontWeight="SemiBold" />
                                    <ComboBox ItemsSource="{Binding PdfExportModes}" SelectedItem="{Binding SelectedPdfExportMode, Mode=TwoWay}" Margin="0,8,0,12" />
                                    <TextBlock Text="页面 DPI" FontWeight="SemiBold" />
                                    <TextBox Text="{Binding PdfPageDpi, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,0" />
                                    <TextBlock Text="96 适合屏幕 100% 查看；300 适合打印归档但屏幕查看会偏小。" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" Margin="0,10,0,0" />
                                </StackPanel>
                            </Border>

                            <Border Background="White" CornerRadius="14" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="14">
                                <StackPanel>
                                    <TextBlock Text="输出目录" FontWeight="Bold" Foreground="#0F172A" />
                                    <TextBox Text="{Binding OutputDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,10,0,12" />
                                    <Button Content="选择目录" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Left" Click="ChooseOutputDirectory_Click" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.ColumnSpan="3" Background="{StaticResource CardBrush}" CornerRadius="16" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="10" Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#F8FAFC" CornerRadius="14" Padding="10,7" VerticalAlignment="Center">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="9" Height="9" CornerRadius="5" Background="{StaticResource PrimaryBrush}" Margin="0,0,8,0" />
                            <TextBlock Text="{Binding CurrentStatus}" Foreground="#0F172A" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <Border Grid.Column="1" Background="#DBEAFE" CornerRadius="10" Padding="10,4" Margin="12,0,0,0">
                            <TextBlock Text="{Binding ProgressValue, StringFormat={}{0:0}%}" Foreground="{StaticResource PrimaryDarkBrush}" FontWeight="Bold" MinWidth="44" TextAlignment="Center" />
                        </Border>

                        <ProgressBar Grid.Row="1" Grid.ColumnSpan="2" Minimum="0" Maximum="100" Value="{Binding ProgressValue}" Margin="0,8,0,0" />
                    </Grid>
                </Border>

                <WrapPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" MaxWidth="300">
                    <Button Content="开始转换" Click="StartConvert_Click" IsEnabled="{Binding CanStart}" MinWidth="78" Margin="0,3,8,3" />
                    <Button Content="合并/拼接" Click="StitchImages_Click" IsEnabled="{Binding CanStart}" Style="{StaticResource SecondaryButtonStyle}" MinWidth="78" Margin="0,3,8,3" />
                    <Button Content="导出 PDF" Click="ExportPdf_Click" IsEnabled="{Binding CanExportPdf}" Style="{StaticResource SecondaryButtonStyle}" MinWidth="78" Margin="0,3,8,3" />
                    <Button Content="停止" Click="StopConvert_Click" IsEnabled="{Binding IsProcessing}" Style="{StaticResource SecondaryButtonStyle}" MinWidth="64" Margin="0,3,8,3" />
                    <Button Content="打开输出文件夹" Click="OpenOutputDirectory_Click" Style="{StaticResource SecondaryButtonStyle}" MinWidth="112" Margin="0,3,0,3" />
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</Window>